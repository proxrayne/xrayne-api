{
  "Serilog": {
    "Using": ["Serilog.Sinks.Console"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      }
    ],
    "Enrich": ["FromLogContext"]
  },
  "AllowedHosts": "*",
  "Cors": {
    "SpaOrigins": [
      "https://localhost:5173",
      "http://localhost:5173",
      "https://127.0.0.1:5173",
      "http://127.0.0.1:5173"
    ]
  },
  "ConnectionStrings": {
    "Default": "Server=localhost;Port=5432;Username=postgres;Password=postgres;Database=xrayne"
  },
  "Jwt": {
    "Issuer": "XRayne",
    "Audience": "XRayne",
    "Secret": "north-velvet-quantum-47-harbor-frosted-citadel",
    "AccessTokenLifetimeMinutes": 7200
  },
  "Docs": true,
  "Xray": {
    "Mode": "library"
  }
}
