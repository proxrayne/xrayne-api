{
  "Serilog": {
    "Using": ["Serilog.Sinks.Console"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      }
    ],
    "Enrich": ["FromLogContext"]
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Default": "Server=localhost;Port=5432;Username=postgres;Password=postgres;Database=xrayne"
  },
  "Jwt": {
    "Issuer": "XRayne",
    "Audience": "XRayne",
    "Secret": "criver-copper-lantern-echo-91-orbit-silent-maple",
    "AccessTokenLifetimeMinutes": 4320
  },
  "Docs": true,
  "Xray": {},
  "NodeConnection": {
    "ReconnectAttempts": 3,
    "InitialReconnectDelaySeconds": 1,
    "ReconnectDelaySeconds": 30,
    "PingTimeoutSeconds": 10,
    "StreamHeartbeatSeconds": 15,
    "StreamIdleTimeoutSeconds": 0,
    "StreamChannelCapacity": 256,
    "LogStreamBatchSize": 50,
    "LogStreamBatchWindowMilliseconds": 250,
    "GrpcKeepAliveDelaySeconds": 60,
    "GrpcKeepAliveTimeoutSeconds": 20,
    "HeartbeatPersistIntervalSeconds": 60,
    "SupervisorIntervalSeconds": 60
  }
}
